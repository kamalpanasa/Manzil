# Copy this file to backend/.env and fill in real values.
# On Replit, add these as Secrets instead of a .env file.

# ── Groq AI ──────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# ── Supabase ──────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Use the "service_role" key (starts with eyJ…) — it lets the backend
# write trips/itinerary on the user's behalf. Keep it server-side only.
# The anon key also works for basic setups.
SUPABASE_KEY=your-service-role-or-anon-key

# ── CORS ──────────────────────────────────────────────────────────
# Set to your frontend URL in production (e.g. https://manzil.app)
FRONTEND_ORIGIN=http://localhost:5000
